# VehiClaw Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────
PORT=3000
BIND_HOST=0.0.0.0          # Use your LAN IP to restrict to local network, e.g. 192.168.1.50
ENABLE_SSL=false            # Set to true if using a domain + cert (requires Caddy/nginx)

# ─────────────────────────────────────────────────────────
# OPENCLAW GATEWAY
# The OpenClaw daemon must be running: openclaw gateway
# ─────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=              # Your OpenClaw gateway token (from openclaw.json)

# ─────────────────────────────────────────────────────────
# AUTH
# VehiClaw generates a token on first run and shows it as a QR code.
# ─────────────────────────────────────────────────────────
AUTH_TOKEN_FILE=./data/auth.token

# ─────────────────────────────────────────────────────────
# GOOGLE MAPS  (required for navigation and nearby search)
# Enable: Directions API, Places API
# https://console.cloud.google.com/ → APIs & Services → Credentials
# ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ─────────────────────────────────────────────────────────
# GOOGLE CALENDAR  (required for calendar features)
# Enable: Google Calendar API, People API
# Download credentials.json (Desktop app type) and place at path below.
# Then run: npm run setup-google
# ─────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=./data/google-credentials.json
GOOGLE_TOKEN_FILE=./data/google-token.json

# ─────────────────────────────────────────────────────────
# OPENWEATHERMAP  (required for weather)
# Free tier: 1000 calls/day
# https://openweathermap.org/api
# ─────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=

# ─────────────────────────────────────────────────────────
# YELP FUSION  (required for restaurant search)
# Free tier: 500 calls/day
# https://www.yelp.com/developers/v3/manage_app
# ─────────────────────────────────────────────────────────
YELP_API_KEY=

# ─────────────────────────────────────────────────────────
# USER PROFILE
# ─────────────────────────────────────────────────────────
USER_NAME=Driver
USER_TIMEZONE=America/New_York    # IANA timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
LOCATION_CITY=                    # Your city (used when GPS isn't available)

# ─────────────────────────────────────────────────────────
# AGENT BEHAVIOR
# ─────────────────────────────────────────────────────────
MAX_HISTORY_TURNS=10     # How many conversation turns to keep in context
DATA_DIR=./data          # Where reminders.db, contacts.json, and tokens live
